# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep secrets out, but allow the placeholder template
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# (.env.example is intentionally NOT ignored so the template can be shared)

# database — must never be committed (contains OAuth/session tokens, user data)
*.db
*.db-journal
*.sqlite
*.sqlite3
/dev.db
/prisma/*.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
