# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# SQLite (開発環境)
DATABASE_URL="file:./dev.db"

# NextAuth
# openssl rand -base64 32 で生成する
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
# Google Cloud Console > 認証情報 > OAuth 2.0 クライアント ID で取得
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ホワイトリスト機能のオン/オフ（false にすると誰でもログイン可能）
WHITELIST_ENABLED=true

# アクセス許可するメールアドレス（カンマ区切り・WHITELIST_ENABLED=true のときのみ有効）
# fail-closed: WHITELIST_ENABLED=true かつ未設定だと誰もログインできない
ALLOWED_EMAILS=you@gmail.com,friend@gmail.com
